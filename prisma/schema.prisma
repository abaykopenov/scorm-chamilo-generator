generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TelegramUser {
  id               String    @id // chat ID as string
  email            String?
  status           String    @default("guest") // guest, pending_code, approved, banned
  authCode         String?
  authCodeExpiresAt DateTime?
  failedAttempts   Int       @default(0)
  generationsCount Int       @default(0)
  documentsCount   Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model GenerationLog {
  id        String   @id @default(cuid())
  chatId    String
  title     String?
  status    String   // started, completed, failed
  createdAt DateTime @default(now())
}
