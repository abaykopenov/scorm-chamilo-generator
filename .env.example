# =============================================================================
# SCORM Chamilo Generator — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# ---------------------------------------------------------------------------
# Security (optional — if not set, API is open)
# ---------------------------------------------------------------------------
# SCORM_API_KEY=your-secret-api-key-here
# SCORM_RATE_LIMIT=30

# ---------------------------------------------------------------------------
# Qdrant Vector Database (optional — falls back to local JSON vectors)
# ---------------------------------------------------------------------------
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_COLLECTION=scorm_material_chunks
# QDRANT_API_KEY=
# QDRANT_ENABLED=true

# ---------------------------------------------------------------------------
# Local LLM Settings
# ---------------------------------------------------------------------------
# LOCAL_LLM_TIMEOUT_MS=180000
# LOCAL_LLM_FETCH_RETRIES=2
# LOCAL_LLM_VERBOSE_LOGS=1
# LOCAL_LLM_OLLAMA_KEEP_ALIVE=20m
# LOCAL_LLM_BASE_URLS=http://127.0.0.1:11434

# Timeouts per stage (ms)
# LOCAL_LLM_BATCH_TIMEOUT_MS=180000
# LOCAL_LLM_LINEPLAN_TIMEOUT_MS=240000
# LOCAL_LLM_MAIN_TIMEOUT_MS=300000
# LOCAL_LLM_WRITER_TIMEOUT_MS=480000

# Logging limits (characters)
# LOCAL_LLM_LOG_MAX_CHARS=1000000
# LOCAL_LLM_LOG_PROMPT_PREVIEW_CHARS=1000000
# LOCAL_LLM_LOG_RESPONSE_PREVIEW_CHARS=1000000
# LOCAL_LLM_LOG_PAYLOAD_MAX_CHARS=1000000

# Generation tuning
# LLM_SEGMENTED_OLLAMA_TOTAL_SCREENS_THRESHOLD=
# LLM_ALLOW_BATCH_DOWNSIZE=false
# LOCAL_LLM_FALLBACK_ON_NETWORK_ERROR=0

# ---------------------------------------------------------------------------
# Telegram Bot (optional)
# ---------------------------------------------------------------------------
# When TELEGRAM_BOT_TOKEN is set and TELEGRAM_BOT_ENABLED is not false,
# `npm run dev` and `npm start` launch Telegram bot together with service.
#
# TELEGRAM_BOT_ENABLED=true
# TELEGRAM_BOT_TOKEN=123456789:telegram-token
# TELEGRAM_BOT_ALLOWED_CHAT_IDS=123456789,987654321
# TELEGRAM_BOT_POLL_TIMEOUT_SECONDS=25
# TELEGRAM_BOT_PROGRESS_STEP_PERCENT=25
# TELEGRAM_BOT_LANGUAGE=ru
# TELEGRAM_BOT_MAX_FILE_SIZE_MB=50
# TELEGRAM_BOT_MAX_CHAT_MATERIALS=12
# TELEGRAM_BOT_MAX_FILE_ENTRIES=40
# TELEGRAM_BOT_RAG_TOP_K=6
#
# Optional generation override for bot requests:
# TELEGRAM_BOT_GENERATION_PROVIDER=template
# TELEGRAM_BOT_GENERATION_MODEL=qwen2.5:14b
# TELEGRAM_BOT_GENERATION_BASE_URL=http://127.0.0.1:11434
# TELEGRAM_BOT_GENERATION_TEMPERATURE=0.2
#
# Optional embedding override for uploaded Telegram files:
# TELEGRAM_BOT_EMBEDDING_PROVIDER=ollama
# TELEGRAM_BOT_EMBEDDING_MODEL=nomic-embed-text
# TELEGRAM_BOT_EMBEDDING_BASE_URL=http://127.0.0.1:11434
